    "chronology": [
      {
        "period": "1863\u5e74",
        "title": "\u65af\u62c9\u7ef4\u4e9a\u7684\u8bde\u751f\u00b7\u5965\u5e1d\u5229\u5e1d\u56fd\u65f6\u4ee3\u7684\u5e03\u62c9\u683c",
        "content": "\u65af\u62c9\u7ef4\u4e9a\u5496\u5561\u9986\u4e8e1863\u5e74\u5f00\u4e1a\uff0c\u6b64\u65f6\u6377\u514b\u5730\u533a\u5c5e\u4e8e\u5965\u5e1d\u5229\u5e1d\u56fd\u7684\u4e00\u90e8\u5206\uff0c\u5e03\u62c9\u683c\u6b63\u5904\u4e8e19\u4e16\u7eaa\u7684\u6587\u5316\u590d\u5174\u671f\u3002\u5f53\u65f6\u6377\u514b\u6c11\u65cf\u4e3b\u4e49\u8fd0\u52a8\u84ec\u52c3\u53d1\u5c55\uff0c\u56fd\u5bb6\u5267\u9662\u6b63\u5728\u7b79\u5efa\u4e2d\uff0c\u5e03\u62c9\u683c\u7684\u6587\u5316\u751f\u6d3b\u65e5\u76ca\u7e41\u8363\u3002\u65af\u62c9\u7ef4\u4e9a\u4f4d\u4e8e\u4f50\u7235\u591a\u6cbf\u5cb8\u6700\u4f73\u5730\u6bb5\uff0c\u5f00\u4e1a\u521d\u671f\u5c31\u4ee5\u5176\u7cbe\u7f8e\u7684\u65b0\u6587\u827a\u590d\u5174\u88c5\u4fee\u548c\u5b8f\u4f1f\u7684\u6cb3\u666f\u7a97\u53e3\u800c\u95fb\u540d\u3002\u201c\u9986\u540dSlavia\u6e90\u81ea\u65af\u62c9\u592b\u8bed\u7cfb\uff0c\u610f\u4e3a\u2018\u65af\u62c9\u592b\u7684\u2019\u2014\u2014\u8fd9\u4e2a\u540d\u5b57\u672c\u8eab\u5c31\u662f\u6377\u514b\u6c11\u65cf\u89c9\u9192\u7684\u5ba3\u8a00\uff1a\u5e03\u62c9\u683c\u4e0d\u518d\u662f\u5965\u5e1d\u5229\u7684\u5730\u65b9\uff0c\u5b83\u662f\u6377\u514b\u7684\u5e03\u62c9\u683c\u201d\u3002\u62db\u724c\u996e\u54c1\u662f\u5965\u5730\u5229\u62c9\u5a1c\u8336\uff08\u62c9\u5a1c\u5496\u5561\u52a0\u6ce1\u672b\u5976\u6cab\uff09\u548c\u7cbe\u9009\u9ed1\u8336\u3002"
      },
      {
        "period": "1863-1900\u5e74",
        "title": "\u56fd\u5bb6\u5267\u9662\u7684\u4f34\u4fa3\u00b7\u6377\u514b\u6587\u5316\u6587\u827a\u590d\u5174",
        "content": "1868\u5e74\uff0c\u56fd\u5bb6\u5267\u9662\u7684\u5730\u57fa\u6b63\u5f0f\u529b\u5899\u2014\u2014\u201c\u6377\u514b\u4eba\u8981\u6709\u81ea\u5df1\u7684\u5267\u9662\uff0c\u7528\u81ea\u5df1\u7684\u8bed\u8a00\uff0c\u5531\u81ea\u5df1\u7684\u6b4c\uff0c\u8bb2\u81ea\u5df1\u7684\u6545\u4e8b\u201d\u3002\u65af\u62c9\u7ef4\u4e9a\u5496\u5561\u9986\u60f0\u6020\u5730\u5750\u5728\u5267\u9662\u5bf9\u9762\uff0c\u6210\u4e3a\u4e86\u6377\u514b\u6587\u827a\u6587\u827a\u590d\u5174\u7684\u201c\u540e\u53f0\u4f11\u606f\u5ba4\u201d\u30021881\u5e74\uff0c\u56fd\u5bb6\u5267\u9662\u6b63\u5f0f\u5f00\u5e55\uff0c\u6f14\u51fa\u4e86\u5fb7\u6c83\u6258\u5c14\u514b\u7684\u6b4c\u5267\u300a\u51e4\u4ed9\u82b1\u300b\uff0c\u201c\u5168\u5e03\u62c9\u683c\u7684\u6377\u514b\u4eba\u90fd\u62e5\u62b1\u5728\u56fd\u5bb6\u5267\u9662\u95e8\u53e3\uff0c\u5f53\u7b2c\u4e00\u4e2a\u6377\u514b\u97f3\u7b26\u5728\u821e\u53f0\u4e0a\u54cd\u8d77\u65f6\uff0c\u65af\u62c9\u7ef4\u4e9a\u7684\u5e38\u5ba2\u4eec\u5747\u5730\u7ad9\u8d77\u6765\u201d\u30021890\u5e74\u4ee3\uff0c\u65af\u62c9\u7ef4\u4e9a\u5df2\u7ecf\u662f\u5e03\u62c9\u683c\u6587\u827a\u5546\u5730\u7684\u5fc3\u810f\uff0c\u8bd7\u4eba\u3001\u4f5c\u5bb6\u3001\u6232\u5267\u5bb6\u548c\u7ed8\u753b\u5bb6\u6bcf\u5929\u805a\u96c6\u5728\u8fd9\u91cc\uff0c\u201c\u65af\u62c9\u7ef4\u4e9a\u7684\u6912\u70df\u7f69\u4f4f\u4e86\u534a\u4e2a\u6377\u514b\u6587\u827a\u754c\u201d\u3002"
      },
      {
        "period": "1918\u5e74",
        "title": "\u6377\u514b\u65af\u6d1b\u4f10\u514b\u72ec\u7acb\u7684\u5386\u53f2\u89c1\u8bc1",
        "content": "1918\u5e7410\u670828\u65e5\uff0c\u6377\u514b\u65af\u6d1b\u4f10\u514b\u5728\u56fd\u5bb6\u5267\u9662\u5ba3\u5e03\u72ec\u7acb\uff0c\u901a\u8fc7\u4e86\u56fd\u5bb6\u7684\u9996\u90e8\u6cd5\u4ee4\u3002\u5e03\u62c9\u683c\u5e02\u6c11\u6d8c\u4e0a\u8857\u5934\u5e86\u795d\uff0c\u65af\u62c9\u7ef4\u4e9a\u4e5f\u6210\u4e3a\u4e86\u6377\u514b\u72ec\u7acb\u5e86\u5178\u7684\u5173\u952e\u573a\u6240\u3002\u201c\u6377\u514b\u65af\u6d1b\u4f10\u514b\u7684\u7b2c\u4e00\u6761\u6cd5\u5f8b\u5728\u56fd\u5bb6\u5267\u9662\u901a\u8fc7\uff0c\u800c\u65af\u62c9\u7ef4\u4e9a\u7684\u5e38\u5ba2\u4eec\u2014\u2014\u5c31\u5728\u5267\u9662\u95e8\u53e3\u7684'Slavia'\u2014\u2014\u7b2c\u4e00\u65f6\u95f4\u5f97\u77e5\u4e86\u8fd9\u4e2a\u6d88\u606f\uff0c\u90a3\u5929\u65af\u62c9\u7ef4\u4e9a\u7684\u8336\u548c\u5496\u5561\u3001\u6211\u7684\u90fd\u9ebb\u4e86\u2014\u2014\u540e\u6765\u4e00\u540d\u5e38\u5ba2\u8fd9\u6837\u56de\u5fc6\u3002\u201d"
      },
      {
        "period": "1920-1930\u5e74\u4ee3",
        "title": "\u6377\u514b\u7384\u5b66\u6d3e\u4e0e\u6587\u827a\u7ea4\u7ec6\u7684\u65af\u62c9\u7ef4\u4e9a",
        "content": "\u4e24\u6218\u4e4b\u95f4\uff0c\u65af\u62c9\u7ef4\u4e9a\u6b63\u5f0f\u6210\u4e3a\u6377\u514b\u73b0\u4ee3\u4e3b\u4e49\u6587\u5b66\u7684\u6469\u897f\u4e1d\u4e4b\u6e2f\u3002\u6377\u514b\u6700\u91cd\u8981\u7684\u4f5c\u5bb6\u51ef\u5c14\u79d1\u5f7b\u00b7\u8d5b\u4f5b\u5170\u00b7\u00b7\u00b7\u00b7\u00b7\u00b7\uff08Karel \u010capek\uff09\u662f\u65af\u62c9\u7ef4\u4e9a\u7684\u5929\u5929\u5e38\u5ba2\u2014\u2014\u4ed6\u5728\u65af\u62c9\u7ef4\u4e9a\u7684\u8336\u684c\u4e0a\u5199\u5b8c\u4e86\u300a\u841c\u5e1b\u8272\u7684\u5f3a\u76ca\u300b\u548c\u300aR.U.R.\u300b\uff08\u201c\u673a\u5668\u4eba\u201dRobot\u8fd9\u4e2a\u8bcd\u7684\u8bde\u751f\u5730\uff09\uff0c\u201c\u8d5b\u4f5b\u5170\u5750\u5728\u65af\u62c9\u7ef4\u4e9a\u9760\u7a97\u7684\u684c\u5b50\u4e0a\uff0c\u4ee5\u4e00\u676f\u62c9\u5a1c\u8336\u4f34\u7740\u4ed6\u7684\u6587\u5b66\u4e16\u754c\u201d\u3002\u8bd7\u4eba\u7c73\u5170\u00b7\u6606\u5fb7\u62c9\u5728\u65af\u62c9\u7ef4\u4e9a\u5199\u5b8c\u4e86\u300a\u4e0d\u80fd\u627f\u5446\u7684\u751f\u547d\u4e4b\u8f7b\u300b\u7684\u6838\u5fc3\u7bc7\u7ae0\uff0c\u201c\u6606\u5fb7\u62c9\u5750\u5728\u65af\u62c9\u7ef4\u4e9a\u7684\u7a97\u8fb9\uff0c\u770b\u7740\u4f50\u7235\u591a\u6cb3\u548c\u56fd\u5bb6\u5267\u9662\uff0c\u7136\u540e\u5199\u4e0b\u4e86\u2018\u5c16\u53eb\u5750\u4e0d\u4f4f\u53c8\u6068\u4e0d\u80fd\u638c\u677e\u7684\u751f\u547d\u2019\u201d\u3002\u8fd8\u6709\u6377\u514b\u6587\u5b66\u5927\u5e08\u8c22\u5c14\u5179\u00b7\u5409\u65af\u5580\u00b7\u00b7\u00b7\u00b7\u00b7\u00b7\u00b7\u00b7\uff08Jaroslav Seifert\uff09\u2014\u20141984\u5e74\u8bfa\u8d1d\u5c14\u6587\u5b66\u5956\u5f97\u4e3b\uff0c\u201c\u5409\u65af\u5580\u5728\u65af\u62c9\u7ef4\u4e9a\u559d\u4e86\u5341\u5e74\u7684\u8336\uff0c\u7136\u540e\u4ed6\u7684\u8bd7\u6b4c\u8d62\u5f97\u4e86\u8bfa\u8d1d\u5c14\u5956\u201d\u3002"
      },
      {
        "period": "1939-1945\u5e74",
        "title": "\u7eb3\u7cb9\u5360\u9886\u65f6\u671f\u7684\u65af\u62c9\u7ef4\u4e9a",
        "content": "1939\u5e74\u7eb3\u7cb9\u5fb7\u56fd\u5360\u9886\u6377\u514b\u65af\u6d1b\u4f10\u514b\uff0c\u5e03\u62c9\u683c\u8fdb\u5165\u201c\u62a4\u56fd\u4e3b\u4f53\u201d\u65f6\u4ee3\u3002\u65af\u62c9\u7ef4\u4e9a\u7684\u7a97\u53e3\u63ae\u4f4f\u4e86\u6c89\u91cd\u7684\u9634\u5f71\u2014\u2014\u7eb3\u7cb9\u58eb\u5175\u5360\u636e\u4e86\u56fd\u5bb6\u5267\u9662\uff0c\u201c\u65af\u62c9\u7ef4\u4e9a\u7684\u8bd7\u4eba\u4eec\u6c89\u9ed8\u4e86\u2014\u2014\u4ed6\u4eec\u4e0d\u518d\u8ba8\u8bba\u6587\u5b66\uff0c\u53ea\u662f\u9ed8\u9ed8\u5730\u559d\u8336\u201d\u3002\u8bb8\u591a\u6377\u514b\u77e5\u8bc6\u5206\u5b50\u88ab\u6293\u6216\u6d41\u4ea1\uff0c\u65af\u62c9\u7ef4\u4e9a\u7684\u684c\u5b50\u4e00\u5f20\u63a5\u4e00\u5f20\u7a7a\u4e86\u4e0b\u6765\u30021942\u5e74\uff0c\u82f1\u56fd\u7279\u5de5\u5c06\u7eb3\u7cb9\u56fd\u7acb\u5e03\u62c9\u683c\u957f\u5b98\u6d77\u56e0\u83f2\u5c14\u00b7\u91cc\u8499\u5fb7\u63f4\u53d2\u6b7b\u4e8e\u6b64\u4e8b\u4ef6\uff0c\u201c\u65af\u62c9\u7ef4\u4e9a\u7684\u5e38\u5ba2\u4eec\u5728\u8336\u684c\u4e0a\u4f4e\u58f0\u4f20\u9012\u7740\u62b5\u6297\u7684\u8bdd\u8bed\uff0c\u8336\u4e0d\u518d\u662f\u8336\uff0c\u662f\u627f\u5446\u7684\u8840\u548c\u80c6\u91cf\u201d\u30021945\u5e74\u5e03\u62c9\u683c\u89e3\u653e\u540e\uff0c\u65af\u62c9\u7ef4\u4e9a\u5f53\u5929\u5c31\u6062\u590d\u4e86\u5f00\u4e1a\uff0c\u201c\u7b2c\u4e00\u676f\u8336\u656c\u7ed9\u56de\u6765\u7684\u6377\u514b\u4eba\u201d\u3002"
      },
      {
        "period": "1948-1977\u5e74",
        "title": "\u5171\u4ea7\u515a\u65f6\u671f\u7684\u6587\u5316\u65cb\u74dc",
        "content": "1948\u5e74\u6377\u514b\u5171\u4ea7\u515a\u63a5\u7ba1\u653f\u6743\u540e\uff0c\u65af\u62c9\u7ef4\u4e9a\u88ab\u56fd\u6709\u5316\u3002\u867d\u7136\u653f\u6cbb\u6c14\u6c1b\u538b\u60ab\uff0c\u4f46\u65af\u62c9\u7ef4\u4e9a\u4ecd\u7136\u662f\u6377\u514b\u6587\u827a\u4eba\u7684\u5e78\u5b58\u4e4b\u5730\u2014\u2014\u201c\u4e0d\u80fd\u5728\u516c\u5f00\u573a\u5408\u8bf4\u7684\u8bdd\uff0c\u5c31\u5728\u65af\u62c9\u7ef4\u4e9a\u7684\u8336\u684c\u4e0a\u8bf4\u201d\u30021968\u5e74\u201c\u5e03\u62c9\u683c\u4e4b\u6625\u201d\u88ab\u82cf\u8054\u538b\u5236\u540e\uff0c\u65af\u62c9\u7ef4\u4e9a\u53d8\u5f97\u5f02\u5e38\u6c89\u9ed8\u2014\u2014\u201c\u6587\u827a\u4eba\u4eec\u5750\u5728\u8001\u5730\u65b9\uff0c\u559d\u8001\u5730\u65b9\u7684\u8336\uff0c\u4f46\u4e0d\u518d\u8bf4\u8bdd\u201d\u30021970\u5e74\u4ee3\uff0c\u5409\u65af\u5580\u7684\u8bd7\u6b4c\u88ab\u7981\uff0c\u4f46\u4ed6\u4ecd\u7136\u6bcf\u5929\u6765\u65af\u62c9\u7ef4\u4e9a\uff0c\u201c\u4ed6\u4e0d\u5e26\u7b14\u548c\u7eb8\uff0c\u4ed6\u53ea\u5e26\u4e00\u53ea\u8336\u676f\uff0c\u9760\u7740\u7a97\u5750\u7740\uff0c\u770b\u6cb3\u6c34\u6d41\u8fc7\u5e03\u62c9\u683c\u201d\u3002"
      },
      {
        "period": "1978-1992\u5e74",
        "title": "\u5929\u9e45\u7ed2\u9769\u547d\u524d\u5915",
        "content": "1978\u5e74\u540e\uff0c\u65af\u62c9\u7ef4\u4e9a\u5b89\u9759\u5730\u62ef\u6548\u4e86\u6377\u514b\u6c11\u95f4\u7684\u6587\u5316\u53cd\u6297\u3002\u6301\u6b65\u4eba\u58eb\u3001\u5a31\u4e50\u793e\u4f1a\u3001\u5929\u4f7f\u4eec\u5728\u65af\u62c9\u7ef4\u4e9a\u4e0e\u77e5\u8bc6\u5206\u5b50\u79d8\u5bc6\u63a5\u89e6\u2014\u2014\u201c\u65af\u62c9\u7ef4\u4e9a\u7684\u8336\u676f\uff0c\u5c31\u662f\u6377\u514b\u7684\u8bdd\u8bed\u6743\u201d\u30021989\u5e74\u5929\u9e45\u7ed2\u9769\u547d\u7206\u53d1\uff0c\u201c\u65af\u62c9\u7ef4\u4e9a\u7684\u5e38\u5ba2\u4eec\u7ec8\u4e8e\u53c8\u53ef\u4ee5\u5927\u58f0\u8ba8\u8bba\u4e86\u201d\u3002\u6377\u514b\u65b0\u9009\u603b\u7edf\u74e6\u7c73\u5c14\u00b7\u54c8\u7ef4\u5c14\u00b7\u00b7\u00b7\uff08V\u00e1clav Havel\uff09\u2014\u2014\u4e00\u4f4d\u6377\u514b\u620f\u5267\u5bb6\u3001\u4ece\u524d\u7684\u725b\u4ed4\u3001\u65af\u62c9\u7ef4\u4e9a\u7684\u5e38\u5ba2\u2014\u2014\u201c\u54c8\u7ef4\u5c14\u5728\u65af\u62c9\u7ef4\u4e9a\u559d\u4e86\u5341\u5e74\u7684\u5496\u5561\uff0c\u7136\u540e\u4ed6\u8fdb\u5165\u4e86\u5e03\u62c9\u683c\u57ce\u5821\u201d\u3002"
      },
      {
        "period": "1993\u5e74\u81f3\u4eca",
        "title": "\u65b0\u65f6\u4ee3\u7684\u65af\u62c9\u7ef4\u4e9a\u00b7\u6377\u514b\u6587\u5316\u7684\u6c38\u6052\u7b7e\u540d",
        "content": "1993\u5e74\u6377\u514b\u65af\u6d1b\u4f10\u514b\u548c\u5e73\u5206\u88c2\u4e3a\u6377\u514b\u548c\u65af\u6d1b\u4f10\u514b\uff0c\u65af\u62c9\u7ef4\u4e9a\u4ecd\u7136\u7acb\u5728\u4f50\u7235\u591a\u6ee8\u3002\u5343\u5e74\u540e\u5929\u5e03\u62c9\u683c\u6210\u4e3a\u6b27\u6d32\u6700\u70ed\u95e8\u7684\u65c5\u6e38\u76ee\u7684\u5730\uff0c\u65af\u62c9\u7ef4\u4e9a\u4ece\u6377\u514b\u4eba\u7684\u65b0\u5ba2\u5385\u53d8\u6210\u4e86\u4e16\u754c\u65c5\u6e38\u76ee\u7684\u5730\u30022017\u5e74\uff0c\u65af\u62c9\u7ef4\u4e9a\u88ab\u6377\u514b\u6587\u5316\u90e8\u5217\u4e3a\u201c\u56fd\u5bb6\u6587\u5316\u8d44\u4ea7\u201d\u2014\u2014\u201c\u4e00\u5ea7\u5496\u5561\u9986\uff0c\u4e00\u676f\u8336\uff0c\u4e00\u4e2a\u56fd\u5bb6\u7684\u516d\u5341\u5e74\u6587\u5316\u201d\u3002\u4eca\u5929\u7684\u65af\u62c9\u7ef4\u5c06\u00b7\u00b7\u00b7\uff0c\u4f60\u53ef\u4ee5\u5728\u8fd9\u91cc\u770b\u5230\u6377\u514b\u65b0\u4e00\u4ee3\u7684\u6587\u827a\u9752\u5e74\u3001\u56fd\u9645\u6e38\u5ba2\u548c\u8001\u4e00\u8f88\u7684\u5e03\u62c9\u683c\u4eba\u540c\u684c\u800c\u5750\u2014\u2014\u201c\u65af\u62c9\u7ef4\u4e9a\u7684\u7a97\u53e3\uff0c\u4ece\u6765\u6ca1\u6709\u53ea\u5c5e\u4e8e\u8c01\u2014\u2014\u5b83\u5c5e\u4e8e\u6377\u514b\u3002\u4e00\u676f\u65af\u62c9\u7ef4\u4e9a\u7684\u8336\u2014\u2014\u662f\u5e03\u62c9\u683c\u7ed9\u4e16\u754c\u7684\u4e00\u4e2a\u5fae\u7b11\u201d\u3002"
      }
    ]
  }
]